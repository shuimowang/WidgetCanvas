<Window x:Class="WidgetCanvas.Windows.CanvasNameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="370" SizeToContent="Height" WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent" ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Border Margin="14" Padding="22,19,22,20" CornerRadius="16"
            Background="#F51A2230" BorderBrush="#526D87A9" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="7" Opacity="0.38" Color="#050911" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="TitleText" Foreground="#F2F6FC" FontSize="16"
                       FontWeight="SemiBold" />
            <TextBox x:Name="NameBox" Grid.Row="1" Height="38" Margin="0,14,0,17"
                     Padding="11,7" MaxLength="30" FontSize="13" Foreground="#EEF4FC"
                     Background="#D9232E40" BorderBrush="#5D7797BE" BorderThickness="1"
                     CaretBrush="#A9D2FF" SelectionBrush="#546FA5D8"
                     KeyDown="NameBox_KeyDown" />
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="70" Height="32" Margin="0,0,8,0"
                        Foreground="#CBD6E6" Background="#243044" BorderBrush="#506984A6"
                        Click="CancelButton_Click" />
                <Button Content="确定" Width="70" Height="32" Foreground="#0F1B2A"
                        Background="#9CCBFA" BorderBrush="#B9DCFF" FontWeight="SemiBold"
                        Click="ConfirmButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
